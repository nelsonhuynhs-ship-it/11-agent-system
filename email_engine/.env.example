# WhatsApp Business API (Meta Cloud API)
# Get from: https://developers.facebook.com/apps/{app_id}/whatsapp-business/wa-dev-console
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=my_webhook_verify_token
WA_API_VERSION=v21.0

# MiniMax LLM API — enables A1 reply extract + A3 smart compose + Panjiva classify
# Get from: https://www.minimax.io/platform/ · Quota: 4500 req/5h on 2.7 plan
# Model override: defaults to MiniMax-M2 (what Nelson's current plan supports).
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2
