# ══════════════════════════════════════════════════════════════
# Nelson Freight System — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in values per machine.

# ── Path Configuration (REQUIRED) ────────────────────────────
# PC Home / Laptop VP: OneDrive paths
# VPS: /opt/nelson paths
NELSON_DATA_DIR=D:\OneDrive\NelsonData
NELSON_LOCAL_DIR=D:\NelsonLocal
NELSON_CODE_DIR=D:\NELSON\2. Areas\Engine_test

# Machine override (auto-detected from hostname if not set)
# Values: pc-home, laptop-vp, vps
# NELSON_MACHINE=laptop-vp

# ── Database ─────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/nelson

# ── Auth ─────────────────────────────────────────────────────
# NELSON_API_KEY=
# ERP_API_KEY=

# ── SMTP (Office 365) ───────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=nelson@pudongprime.vn
# SMTP_PASS=

# ── Telegram Bot ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALERT_CHAT_ID=

# ── AI ───────────────────────────────────────────────────────
# GEMINI_API_KEY=
