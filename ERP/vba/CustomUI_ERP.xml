<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
  onLoad="RibbonOnLoad">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="tabOperations" label="Operations" visible="true">

        <!-- ====== GROUP 1: ROUTE INFO (read-only labels) ====== -->
        <group id="grpInfo" label="Route Info">
          <labelControl id="lblCarrierBadge" getLabel="GetLabel_CarrierBadge"/>
          <labelControl id="lblRoute"        getLabel="GetLabel_Route"/>
          <labelControl id="lblVoyage"       getLabel="GetLabel_Voyage"/>
          <labelControl id="lblDates"        getLabel="GetLabel_Dates"/>
        </group>

        <!-- ====== GROUP 2A: BUY RATE - DRY (read-only) ====== -->
        <group id="grpBuyDry" label="Buy Rate (USD)">
          <editBox id="eb20GP"  label="20GP"  sizeString="000000"
                   getText="GetText_Buy20GP"  enabled="false"/>
          <editBox id="eb40GP"  label="40GP"  sizeString="000000"
                   getText="GetText_Buy40GP"  enabled="false"/>
          <editBox id="eb40HC"  label="40HC"  sizeString="000000"
                   getText="GetText_Buy40HC"  enabled="false"/>
          <editBox id="eb45HC"  label="45HC"  sizeString="000000"
                   getText="GetText_Buy45HC"  enabled="false"/>
          <editBox id="eb40NOR" label="40NOR" sizeString="000000"
                   getText="GetText_Buy40NOR" enabled="false"/>
        </group>

        <!-- ====== GROUP 2B: BUY RATE - REEFER (read-only) ====== -->
        <group id="grpBuyReefer" label="Buy Reefer">
          <editBox id="eb20RF" label="20RF" sizeString="000000"
                   getText="GetText_Buy20RF" enabled="false"/>
          <editBox id="eb40RF" label="40RF" sizeString="000000"
                   getText="GetText_Buy40RF" enabled="false"/>
        </group>

        <!-- ====== GROUP 3A: MARGIN - DRY (editable) ====== -->
        <group id="grpMarginDry" label="+ Margin">
          <editBox id="ebM20"    label="20GP +"  sizeString="00000"
                   getText="GetText_Mar20"   onChange="OnChange_Mar20"/>
          <editBox id="ebM40GP"  label="40GP +"  sizeString="00000"
                   getText="GetText_Mar40GP" onChange="OnChange_Mar40GP"/>
          <editBox id="ebM40HC"  label="40HC +"  sizeString="00000"
                   getText="GetText_Mar40HC" onChange="OnChange_Mar40HC"/>
          <editBox id="ebM45"    label="45HC +"  sizeString="00000"
                   getText="GetText_Mar45"   onChange="OnChange_Mar45"/>
          <editBox id="ebM40NOR" label="40NOR +" sizeString="00000"
                   getText="GetText_Mar40NOR" onChange="OnChange_Mar40NOR"/>
        </group>

        <!-- ====== GROUP 3B: MARGIN - REEFER (editable) ====== -->
        <group id="grpMarginReefer" label="+ Margin RF">
          <editBox id="ebM20RF" label="20RF +" sizeString="00000"
                   getText="GetText_Mar20RF" onChange="OnChange_Mar20RF"/>
          <editBox id="ebM40RF" label="40RF +" sizeString="00000"
                   getText="GetText_Mar40RF" onChange="OnChange_Mar40RF"/>
        </group>

        <!-- ====== GROUP 4: PUC (SOC only) ====== -->
        <group id="grpPUC" label="PUC (SOC)">
          <labelControl id="lblPUC20"  getLabel="GetLabel_PUC20"/>
          <labelControl id="lblPUC40"  getLabel="GetLabel_PUC40"/>
          <labelControl id="lblPUC40HC" getLabel="GetLabel_PUC40HC"/>
        </group>

        <!-- ====== GROUP 5: SELL RATE (calculated labels) ====== -->
        <group id="grpSell" label="= Sell Rate">
          <labelControl id="lblSell20"    getLabel="GetLabel_Sell20"/>
          <labelControl id="lblSell40GP"  getLabel="GetLabel_Sell40GP"/>
          <labelControl id="lblSell40HC"  getLabel="GetLabel_Sell40HC"/>
          <labelControl id="lblSell45HC"  getLabel="GetLabel_Sell45HC"/>
          <labelControl id="lblSell40NOR" getLabel="GetLabel_Sell40NOR"/>
          <labelControl id="lblSell20RF"  getLabel="GetLabel_Sell20RF"/>
          <labelControl id="lblSell40RF"  getLabel="GetLabel_Sell40RF"/>
          <separator id="sepProfit"/>
          <labelControl id="lblProfit"    getLabel="GetLabel_Profit"/>
        </group>

        <!-- ====== GROUP 6: QUOTE ACTION ====== -->
        <group id="grpAction" label="Quote">
          <editBox id="ebCustomer" label="Customer" sizeString="000000000000"
                   onChange="OnChange_Customer"/>
          <separator id="sepQuote"/>
          <button id="btnQuote" label="QUOTE" size="large"
                  imageMso="CreateTable" onAction="GenerateQuote"/>
        </group>

        <!-- ====== GROUP 7: QUOTE STATUS (Win/Lost/Expired) ====== -->
        <group id="grpQuoteManage" label="Quote Status">
          <button id="btnWin"
            label="WIN" size="large"
            imageMso="AcceptInvitation"
            onAction="MarkQuoteWin"
            screentip="Mark selected quote as WON and create Active Job"/>
          <button id="btnLost"
            label="LOST" size="large"
            imageMso="DeclineInvitation"
            onAction="MarkQuoteLost"
            screentip="Mark selected quote as LOST with reason"/>
          <separator id="sep2"/>
          <button id="btnExpired"
            label="Check Expired" size="normal"
            imageMso="RecurrenceEdit"
            onAction="CheckAutoLost"
            screentip="Auto-expire quotes past Exp date"/>
        </group>

        <!-- ====== GROUP 8: REPORTS ====== -->
        <group id="grpReport" label="Reports">
          <button id="btnMonthlyReport"
            label="Monthly Report"
            size="large"
            imageMso="TableExportToSharePointList"
            onAction="ExportMonthlyReport"
            screentip="Export monthly profit report by FAST JOB NO"/>
        </group>

      </tab>
    </tabs>
  </ribbon>
</customUI>
