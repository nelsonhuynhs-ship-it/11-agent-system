  "soc_compliance": {
    "scope": "Southeast Asia (VN, TH, PH, MY, ID) & China",
    "updated": "2026-03",
    "container_requirements": {
      "age_limit": {
        "rule": "Container > 5 years (from manufacturing date on CSC plate) MUST have valid ACEP inspection label",
        "acep_label": {
          "size_cm": "7.5 x 3.5",
          "format": "Decal sticker",
          "placement": "Directly on CSC plate in ACEP section",
          "next_inspection": "Max 2.5 years from current inspection date",
          "typical_validity": "1 year from container pickup date",
          "example": "Container picked up 03/03/2026 → ACEP label shows 'Mar.2027' (punch hole per IMO standard)"
        }
      },
      "original_condition": "No modifications allowed since original manufacturing",
      "cargo_type": "Non-DG (Dangerous Goods) ONLY",
      "prefix_restriction": "Container prefix must NOT be in ONE's banned prefix list (or alliance partners' banned list)"
    },
    "booking_process": {
      "step_1": "Obtain container number",
      "step_2": "Customer provides full container photos (all sides) for ONE system registration",
      "deadlines": {
        "direct_services": "At least 2 working days BEFORE SI cut-off",
        "transit_services": "At least 2 working days BEFORE CY cut-off"
      },
      "rejection_warning": "If conditions not met → ONE REJECTS shipment. All incurred costs will NOT be resolved."
    },
    "acep_support": {
      "option_1": "Outsource operator — contact Log Team (Ms. Liana) for case-by-case pricing",
      "option_2": "SOC Team provides ACEP labels if customer handles application themselves"
    },
    "customer_owned_container": {
      "requirements": [
        "Container must have valid inspection within deadline + ACEP label on CSC plate",
        "Container must have valid inspection certificate per IMO standards",
        "Full container photos must be provided (all angles)"
      ]
    },
    "checklist_before_booking": [
      "Container age < 5 years OR valid ACEP label present",
      "No structural modifications on container",
      "Cargo is Non-DG",
      "Prefix not in banned list",
      "Full container photos taken and submitted",
      "Submitted at least 2 working days before SI/CY cut-off"
    ]
  }
