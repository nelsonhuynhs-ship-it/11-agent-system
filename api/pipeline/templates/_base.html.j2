<!DOCTYPE html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"></head>
<body style="font-family:Arial,sans-serif;font-size:14px;color:#333;line-height:1.6;max-width:600px;margin:0 auto">
{% block content %}{% endblock %}

<div style="margin-top:30px;padding-top:15px;border-top:1px solid #eee;font-size:12px;color:#999">
<p><strong>{{ sender_name | default('Nelson Huynh') }}</strong><br>
{{ sender_title | default('Freight Specialist') }} — {{ sender_company | default('Team Sunny Logistics') }}<br>
{{ sender_email | default('') }} | {{ sender_phone | default('') }}</p>
</div>
</body></html>
